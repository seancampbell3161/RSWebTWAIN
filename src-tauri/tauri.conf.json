{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/config.schema.json",
  "productName": "Scan Agent",
  "version": "0.1.0",
  "identifier": "com.scanagent.app",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "frontendDist": "./frontend"
  },
  "app": {
    "withGlobalTauri": false,
    "trayIcon": {
      "iconPath": "icons/tray-icon.png",
      "iconAsTemplate": false
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/twain-scanner-32bit"],
    "windows": {
      "wix": {
        "language": "en-US",
        "upgradeCode": "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["scan-agent"]
      }
    },
    "shell": {
      "sidecar": true,
      "scope": [
        {
          "name": "binaries/twain-scanner-32bit",
          "sidecar": true
        }
      ]
    }
  }
}
